# Copy to .env and adjust. All values have sane defaults in app/config.py.

# ── Service ───────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Models ────────────────────────────────────────────────────────────────
# Leave MODEL_PATH empty to auto-pick the newest logo_detection/runs/*/weights/best.pt
MODEL_PATH=
# Body-zone pose helper only (logo detection uses the YOLO26m weights above).
# YOLO26 has no pose variant yet; YOLO11-pose is the newest available.
POSE_MODEL=yolo11n-pose.pt
DEVICE=auto            # auto | cpu | mps | cuda | 0

# ── Inference / sampling ──────────────────────────────────────────────────
SAMPLE_FPS=2.0         # frames analysed per second of video
IMGSZ=1280             # model trained at 1280; lower (e.g. 960) for speed
CONF=0.25
ENABLE_POSE=true       # body-zone attribution via YOLO-pose

# ── Infrastructure (swap these to promote to full production stack) ───────
STORAGE_BACKEND=local
DB_URL=                # empty -> sqlite:///backend/data/app.db ; set postgres URL later
QUEUE_BACKEND=inprocess
WORKER_CONCURRENCY=1

# ── Upload limits ─────────────────────────────────────────────────────────
MAX_UPLOAD_MB=2048
